# ──────────────────────────────────────────────────────────────
# Stellar Passport — environment template. Copy to apps/web/.env.local
# NEVER commit the real .env.local (see .gitignore). See 00-strategy §4/§7.
# ──────────────────────────────────────────────────────────────

# --- Network (testnet by default; switch to mainnet at Black belt) ---
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# --- Deployed contract IDs (fill after `stellar contract deploy`) ---
NEXT_PUBLIC_REPUTATION_CONTRACT_ID=
NEXT_PUBLIC_QUEST_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_REWARDS_CONTRACT_ID=
# On-chain username/handle registry (handle ↔ address; powers public /u/<handle>).
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=
# Reputation-gating (Earned/Social XP → access). Composable: any app can check(addr, gate).
NEXT_PUBLIC_GATE_CONTRACT_ID=
# The quest id the dashboard "Verify a quest" button targets. Must be a quest the attester
# is allowlisted for (see scripts/deploy-testnet.sh). Defaults to 2 if unset.
NEXT_PUBLIC_DEFAULT_QUEST_ID=2

# --- USDC SAC (testnet placeholder; use canonical Circle SAC on mainnet) ---
NEXT_PUBLIC_USDC_SAC_ID=

# --- Passkey smart-wallet infra (passkey-kit). Set the wallet WASM hash to OFFER passkey
#     onboarding; otherwise the app falls back to a testnet dev wallet (Friendbot). The
#     relayer URL + key are SERVER-only (used in /api/passkey-send) and sponsor fees so the
#     user needs no XLM. Generate a free testnet key: curl https://channels.openzeppelin.com/testnet/gen
#     Runbook: docs/PASSKEY_HANDOFF.md. ---
NEXT_PUBLIC_PASSKEY_WALLET_WASM_HASH=
PASSKEY_RELAYER_URL=https://channels.openzeppelin.com/testnet
PASSKEY_RELAYER_API_KEY=

# --- Fee sponsorship (paymaster). Public key shown client-side; secret stays server-only ---
NEXT_PUBLIC_SPONSOR_PUBLIC_KEY=
SPONSOR_SECRET_KEY=

# --- Attester (SERVER-ONLY, used by /api/attest serverless route). Allowlisted on-chain ---
# Generate with: stellar keys generate attester  (then add its public key via add_attester)
ATTESTER_SECRET_KEY=

# --- GitHub PR auto-verification quest (optional; Orange belt) ---
GITHUB_TOKEN=

# --- USDC test faucet (SERVER-ONLY, used by /api/faucet; TESTNET ONLY) ---
# Secret key of the USDC issuer; the faucet pays test USDC to wallets that hold the
# trustline. Never set this on mainnet — we never mint real USDC.
USDC_ISSUER_SECRET_KEY=

# --- Anchor off-ramp + proof-of-funding (reserved; SEP-24/SEP-12 wired at Black belt) ---
NEXT_PUBLIC_ANCHOR_HOME_DOMAIN=
NEXT_PUBLIC_ANCHOR_TRANSFER_SERVER=
